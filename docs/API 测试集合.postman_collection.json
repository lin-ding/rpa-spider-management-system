              "raw": "{\n  \"parentId\": 1,\n  \"menuName\": \"测试菜单\",\n  \"menuType\": 2,\n  \"path\": \"/test\",\n  \"component\": \"test/index\",\n  \"permission\": \"test:list\",\n  \"icon\": \"test\",\n  \"sortOrder\": 10,\n  \"status\": 1,\n  \"visible\": 1\n}"
